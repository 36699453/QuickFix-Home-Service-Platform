@model QuickFix.web.Models.Service

@{
    ViewData["Title"] = "Edit Service";
}

<div class="container mt-5 mb-5">

    <div class="card shadow">

        <div class="card-header bg-warning">

            <h3>Edit Service</h3>

        </div>

        <div class="card-body">

            <form asp-action="Edit">

                <input asp-for="Id" type="hidden" />

                <div class="mb-3">

                    <label>Service Name</label>

                    <input asp-for="ServiceName"
                           class="form-control" />

                </div>

                <div class="mb-3">

                    <label>Description</label>

                    <textarea asp-for="Description"
                              class="form-control"></textarea>

                </div>

                <div class="mb-3">

                    <label>Price</label>

                    <input asp-for="Price"
                           class="form-control" />

                </div>

                <div class="mb-3">

                    <label>Image URL</label>

                    <input asp-for="ImageUrl"
                           class="form-control" />

                </div>

                <div class="mt-3">

                    <button type="submit" class="btn btn-warning">
                        💾 Update Service
                    </button>

                    <a asp-action="Index"
                       class="btn btn-secondary ms-2">

                        Cancel

                    </a>

                </div>

            </form>

        </div>

    </div>

</div>