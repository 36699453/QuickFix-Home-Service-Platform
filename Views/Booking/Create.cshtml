@model QuickFix.web.Models.Booking

@{
    ViewData["Title"] = "Book Home Service";
}

<div class="container mt-5">

    <div class="row justify-content-center">

        <div class="col-lg-8">

            <div class="card shadow-lg border-0 rounded-4">

                <div class="card-header bg-primary text-white text-center">

                    <h2>📅 Book Your Service</h2>
                    <p class="mb-0">Fill in your details to confirm your booking.</p>

                </div>

                <div class="card-body p-4">

                    <form asp-action="Create" method="post">

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <input asp-for="ServiceId" type="hidden" />

                        <div class="mb-3">
                            <label asp-for="CustomerName" class="form-label"></label>
                            <input asp-for="CustomerName" class="form-control" />
                            <span asp-validation-for="CustomerName" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Phone" class="form-label"></label>
                            <input asp-for="Phone" class="form-control" />
                            <span asp-validation-for="Phone" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Address" class="form-label"></label>
                            <textarea asp-for="Address" rows="3" class="form-control"></textarea>
                            <span asp-validation-for="Address" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Problem" class="form-label"></label>
                            <textarea asp-for="Problem" rows="3" class="form-control"></textarea>
                            <span asp-validation-for="Problem" class="text-danger"></span>
                        </div>

                        <div class="row">

                            <div class="col-md-6 mb-3">
                                <label asp-for="BookingDate" class="form-label"></label>
                                <input asp-for="BookingDate" type="date" class="form-control" />
                                <span asp-validation-for="BookingDate" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="BookingTime" class="form-label"></label>
                                <input asp-for="BookingTime" type="time" class="form-control" />
                                <span asp-validation-for="BookingTime" class="text-danger"></span>
                            </div>

                        </div>

                        <div class="d-grid mt-4">

                            <button type="submit" class="btn btn-success btn-lg">

                                ✅ Confirm Booking

                            </button>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts
{
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}